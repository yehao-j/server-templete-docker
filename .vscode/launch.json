{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach Backend in Docker",
      "type": "pwa-node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9229,
      "restart": true,
      "localRoot": "${workspaceFolder}/backend",
      "remoteRoot": "/app/backend",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Open Frontend in Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}
